    "privacy.item.external.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "We do not collect or transmit any personally identifiable information."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
