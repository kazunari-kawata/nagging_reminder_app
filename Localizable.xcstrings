    "privacy.item.notification.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Notifications are sent at the scheduled time as task reminders. You can change notification permissions at any time in System Settings."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タスクのリマインダーとして、設定した日時に通知を送信します。通知の許可はいつでもシステム設定から変更できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
