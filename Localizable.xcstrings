    },
    "privacy.item.ads.body" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This app may display ads using Google AdMob. AdMob may use your device's advertising ID. Please refer to Google's Privacy Policy for details."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "このアプリはGoogle AdMobを使用して広告を表示することがあります。AdMobは端末の広告IDを使用する場合があります。詳細はGoogleのプライバシーポリシーをご参照ください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 앱은 Google AdMob을 사용하여 광고를 표시할 수 있습니다. AdMob은 기기의 광고 ID를 사용할 수 있습니다. 자세한 내용은 Google 개인정보 처리방침을 참조하세요."
          }
        }
      }
    },
