    "onboarding.step1.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tap the \"+ Add Task\" button at the top of the home screen. Set a name, time, and repeat schedule — Baddger will keep nagging you until it's done."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ホーム画面の「+ タスクを追加」ボタンをタップ。名前・時間・繰り返し設定をしたら、あとはBaddgerが完了するまでしつこく通知します。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "홈 화면 상단의 \"+ 할 일 추가\" 버튼을 탭하세요. 이름, 시간, 반복 일정을 설정하면 Baddger가 완료할 때까지 끈질기게 알림을 보냅니다."
          }
        }
      }
    },
    "onboarding.step1.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Add a Task"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タスクを追加しよう"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "할 일 추가하기"
          }
        }
      }
    },
    "onboarding.step2.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Finished a task? Swipe the card a little to the left. When the card turns green, release to mark it as Done and stop the nagging."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タスクが終わったら、カードを少し左にスワイプ。カードが緑になったら指を離すと完了になり、通知が止まります。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "할 일을 완료했다면 카드를 살짝 왼쪽으로 스와이프하세요. 카드가 초록색으로 바뀌면 손가락을 놓으면 완료 처리되고 알림이 멈춥니다."
          }
        }
      }
    },
    "onboarding.step2.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Short Left Swipe → Done"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "少し左スワイプ → 完了"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "짧게 왼쪽 스와이프 → 완료"
          }
        }
      }
    },
    "onboarding.step3.description" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "To delete a task, swipe it far to the left (past 70% of the card). When the card turns red, release to delete it completely."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タスクを削除したいときは、カードを大きく左にスワイプ（カードの幅の約7割以上）。赤くなったら離すと完全に削除されます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "할 일을 삭제하려면 카드를 왼쪽으로 크게 스와이프하세요(카드 너비의 약 70% 이상). 빨간색으로 바뀌면 손가락을 놓으면 완전히 삭제됩니다."
          }
        }
      }
    },
    "onboarding.step3.title" : {
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Long Left Swipe ← Delete"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "大きく左スワイプ ← 削除"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "크게 왼쪽 스와이프 ← 삭제"
          }
        }
      }
    },
